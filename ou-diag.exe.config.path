<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Oracle.DataAccess"
                          publicKeyToken="89b483f429c47342"
                          culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-2.122.1.0"
                         newVersion="2.122.1.0"/>
        <codeBase version="2.122.1.0"
                  href="file:///C:/Oracle/Ora12_32/client/odp.net/bin/2.x/Oracle.DataAccess.dll"/>
      </dependentAssembly>
    </assemblyBinding>
  </runtime>

  <system.data>
    <DbProviderFactories>
      <add name="Oracle Data Provider for .NET"
           invariant="Oracle.DataAccess.Client"
           description="Oracle Data Provider for .NET"
           type="Oracle.DataAccess.Client.OracleClientFactory,
                 Oracle.DataAccess, Version=2.122.1.0,
                 Culture=neutral, PublicKeyToken=89b483f429c47342"/>
    </DbProviderFactories>
  </system.data>

  <connectionStrings>
    <!-- Replace the values below with your actual TNS alias or EZConnect string -->
    <add name="MyConn"
         providerName="Oracle.DataAccess.Client"
         connectionString="User Id=SCOTT;Password=TIGER;Data Source=ORCLPDB1"/>
  </connectionStrings>
</configuration>
